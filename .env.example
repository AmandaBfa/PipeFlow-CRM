# PipeFlow CRM — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com os valores reais.
# Apenas variáveis NEXT_PUBLIC_* chegam ao browser. As demais são somente-servidor.

# Supabase — Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Dashboard > Developers > API keys / Webhooks (test mode)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Resend — Dashboard > API Keys
RESEND_API_KEY=

# URL pública da aplicação (dev: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
